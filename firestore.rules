rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    // The trip document for a given id (used to authorize trip-scoped content).
    function tripData(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId)).data;
    }

    // True when the signed-in user owns or has been granted access to the trip.
    // Membership is driven entirely by the trip document, so removing someone
    // from collaboratorIds / collaboratorEmails immediately revokes their access
    // to every piece of that trip's content — without touching their auth session.
    function isMemberOfTrip(trip) {
      return isSignedIn() && (
        trip.userId == request.auth.uid ||
        (trip.collaboratorIds != null && request.auth.uid in trip.collaboratorIds) ||
        (trip.collaboratorEmails != null && authEmail() in trip.collaboratorEmails)
      );
    }

    function isTripMember(tripId) {
      return isMemberOfTrip(tripData(tripId));
    }

    // The primary owner or any co-owner (ownerIds) has owner privileges.
    function isOwnerOfTrip(trip) {
      return isSignedIn() && (
        trip.userId == request.auth.uid ||
        (trip.ownerIds != null && request.auth.uid in trip.ownerIds)
      );
    }

    // Owners, plus collaborators the owner granted direct schedule-edit rights.
    function canEditSchedule(trip) {
      return isOwnerOfTrip(trip) ||
        (trip.scheduleEditorIds != null && request.auth.uid in trip.scheduleEditorIds);
    }
    function tripCanEditSchedule(tripId) {
      return canEditSchedule(tripData(tripId));
    }

    // ── Trips ───────────────────────────────────────────────────────────────
    // Owner has full control. Members can read and update. A bearer of a live
    // invite token can read (to verify the token) and add themselves as a member.
    match /trips/{tripId} {
      allow read: if isSignedIn() && (
        isMemberOfTrip(resource.data) ||
        resource.data.inviteToken != null
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Members can edit the trip, but only owners may change ownership fields
        // (ownerIds / userId) — this prevents a collaborator self-promoting.
        ( isMemberOfTrip(resource.data) && (
            isOwnerOfTrip(resource.data) ||
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerIds', 'userId', 'scheduleEditorIds', 'shareToken', 'shareEnabled'])
          )
        ) ||
        // Invite-token acceptance: token bearer may add only themselves.
        (resource.data.inviteToken != null &&
         request.resource.data.collaboratorIds != null &&
         request.auth.uid in request.resource.data.collaboratorIds)
      );
      allow delete: if isOwnerOfTrip(resource.data);
    }

    // ── Trip-scoped content — members only ──────────────────────────────────
    // Read/write requires membership of the parent trip, so a removed
    // collaborator can no longer touch any of it.
    match /bookings/{bookingId} {
      allow read, delete: if isTripMember(resource.data.tripId);
      allow create: if isTripMember(request.resource.data.tripId);
      allow update: if isTripMember(resource.data.tripId)
                    && isTripMember(request.resource.data.tripId);
    }

    match /itinerary/{itemId} {
      allow read: if isTripMember(resource.data.tripId);

      // Schedule editors (owners + granted collaborators) create directly.
      // Other members may only create a PROPOSED item attributed to themselves.
      allow create: if isTripMember(request.resource.data.tripId) && (
        tripCanEditSchedule(request.resource.data.tripId) ||
        ( request.resource.data.proposed == true
          && request.resource.data.proposedBy == request.auth.uid )
      );

      // Editors update anything (incl. approving: proposed -> false). A proposer
      // may edit their own proposal but cannot approve it (must stay proposed).
      allow update: if isTripMember(resource.data.tripId)
                    && isTripMember(request.resource.data.tripId) && (
        tripCanEditSchedule(resource.data.tripId) ||
        ( resource.data.proposedBy == request.auth.uid
          && request.resource.data.proposed == true )
      );

      // Editors delete anything (reject); a proposer may withdraw their own proposal.
      allow delete: if isTripMember(resource.data.tripId) && (
        tripCanEditSchedule(resource.data.tripId) ||
        resource.data.proposedBy == request.auth.uid
      );
    }

    match /expenses/{expenseId} {
      allow read, delete: if isTripMember(resource.data.tripId);
      allow create: if isTripMember(request.resource.data.tripId);
      allow update: if isTripMember(resource.data.tripId)
                    && isTripMember(request.resource.data.tripId);
    }

    match /packingItems/{itemId} {
      allow read, delete: if isTripMember(resource.data.tripId);
      allow create: if isTripMember(request.resource.data.tripId);
      allow update: if isTripMember(resource.data.tripId)
                    && isTripMember(request.resource.data.tripId);
    }

    // ── Photos ──────────────────────────────────────────────────────────────
    // Members can view the shared gallery; the uploader can edit captions;
    // any trip member can delete (so orphan-cleanup of dangling docs works
    // regardless of who first hits the broken image, and so trip owners can
    // moderate the shared album).
    match /photos/{photoId} {
      allow read: if isTripMember(resource.data.tripId);
      allow create: if isTripMember(request.resource.data.tripId)
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isTripMember(resource.data.tripId);
    }

    // ── Trip Documents ────────────────────────────────────────────────────────
    match /tripDocuments/{docId} {
      allow read: if isTripMember(resource.data.tripId);
      allow create: if isTripMember(request.resource.data.tripId)
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Participants ─────────────────────────────────────────────────────────
    // Trip members manage the roster. An invitee may also find their own pending
    // invite (by email) and claim it, and may delete their own record (leave).
    match /participants/{participantId} {
      allow read: if isTripMember(resource.data.tripId)
        || (resource.data.userId != null && resource.data.userId == request.auth.uid)
        || (resource.data.inviteEmail != null && resource.data.inviteEmail == authEmail());
      allow create: if isTripMember(request.resource.data.tripId);
      allow update: if isTripMember(resource.data.tripId)
        || (resource.data.inviteEmail != null
            && resource.data.inviteEmail == authEmail()
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.tripId == resource.data.tripId);
      allow delete: if isTripMember(resource.data.tripId)
        || (resource.data.userId != null && resource.data.userId == request.auth.uid);
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    // Readable by any signed-in user (needed to resolve member names and to look
    // up an invitee by email). Writable only by the owner of the profile.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
