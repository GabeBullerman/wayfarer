rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Trip cover photos (signed-in read, owner write) ────────────────────
    // Note: in-app <img> uses tokenized download URLs which work regardless;
    // requiring auth here just blocks unauthenticated enumeration.
    match /coverPhotos/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Trip photos (shared: any signed-in user can read; only uploader can delete) ──
    match /photos/{userId}/{tripId}/{fileName} {
      // Any signed-in user can read — shared gallery
      allow read: if request.auth != null;
      // Only the uploader can write (upload) to their own folder
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 15 * 1024 * 1024  // 15 MB max
        && request.resource.contentType.matches('image/.*');
      // Only the uploader can delete their own photo
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Trip documents (any file type, 25 MB max, signed-in only) ────────────
    match /documents/{userId}/{tripId}/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024;  // 25 MB max, any content type
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
