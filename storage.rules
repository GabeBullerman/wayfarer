rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Trip cover photos (public read, owner write) ───────────────────────
    match /coverPhotos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Trip photos (shared: any signed-in user can read; only uploader can delete) ──
    match /photos/{userId}/{tripId}/{fileName} {
      // Any signed-in user can read — shared gallery
      allow read: if request.auth != null;
      // Only the uploader can write (upload) to their own folder
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 15 * 1024 * 1024  // 15 MB max
        && request.resource.contentType.matches('image/.*');
      // Only the uploader can delete their own photo
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
